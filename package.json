{
  "name": "ghibli",
  "version": "1.1.2",
  "author": {
    "name": "Zak White"
  },
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.265",
    "@types/node": "^16.11.58",
    "@types/react": "^18.0.18",
    "@types/react-dom": "^18.0.6",
    "typescript": "^4.8.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "quick": "npm run build --ignore-scripts",
    "options": "open -a \"Google Chrome\" ./public/options.html",
    "build": "INLINE_RUNTIME_CHUNK=false react-scripts build",
    "postbuild": "rm -f build.zip && zip -qr build build/",
    "prebuild": "python3 scripts/scrape.py > src/json/stills.json; cat src/json/stills.json | python3 scripts/CGIfilter.py > src/json/filtered.json",
    "version": "node scripts/version-sync.js && git add public"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
